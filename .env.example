# --- Furiosa LLM (OpenAI 호환) ---
# 실제 키는 GCP Secret Manager 에 있다: llm-api-key / embed-api-key / rerank-api-key
LLM_BASE_URL=https://endpoint.access.furiosa.dev/v1
LLM_API_KEY=
LLM_MODEL=furiosa-ai/Qwen3-32B-FP8
LLM_PROVIDER=openai_compat
# Qwen3 는 추론 모델이라 끄지 않으면 응답이 잘린다. 반드시 1 로 둘 것.
LLM_DISABLE_THINKING=1

EMBED_API_KEY=
RERANK_API_KEY=

# --- GCP ---
GCP_PROJECT=mindlens-furiosa-2026

# --- Cloud SQL ---
INSTANCE_CONNECTION_NAME=mindlens-furiosa-2026:asia-northeast3:mindlens-db
DB_USER=postgres
DB_PASSWORD=
DB_NAME=mindlens

# --- 배포 연결 ---
PUBLIC_WEB_BASE=
CORS_ORIGINS=*

# --- 알림 (Discord) ---
# Discord 채널 웹훅 URL. 실값은 Secret Manager. 비우면 알림 비활성.
DISCORD_WEBHOOK_URL=
